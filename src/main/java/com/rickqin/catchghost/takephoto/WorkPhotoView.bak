    @Override
    public void beforeEnter(BeforeEnterEvent event) {

        Map<String, List<String>> params = event.getLocation()
                .getQueryParameters()
                .getParameters();

        // URL参数合法性验证
        if (params.containsKey("workorder")) {
            String workorder = params.get("workorder").get(0);
            if (workorder != null && workorder.matches(REGEX_WORKORDER)) {
                txtWorkOrder.setValue(workorder);
                txtWorkOrder.setReadOnly(true);
            } else {
                txtWorkOrder.setReadOnly(false);
                notibox.open("Workorder number is invalid. Please enter it manually.", NotiBox.NotiType.ERROR);
            }
        } else {
            txtWorkOrder.clear();
            txtWorkOrder.setReadOnly(false);
        }
    }

    private boolean validateWorkorderField() {
        if (StringUtils.isBlank(txtWorkOrder.getValue())
                || !txtWorkOrder.getValue().trim().matches(REGEX_WORKORDER)) {
            notibox.open("Workorder number is invalid. Please check it.", NotiBox.NotiType.ERROR);
            txtWorkOrder.focus();
            return false;
        } else {
            return true;
        }
    }

    private void processFinalSave(String base64Data, String workorder, String notes) {
        try {
            photoService.savePhoto(base64Data, workorder, notes);
            notibox.open("Photo has been uploaded.", NotiBox.NotiType.SUCCESSFUL);
        } catch (Exception ex) {
            notibox.open("Failed to save photo: " + ex.getMessage(), NotiBox.NotiType.ERROR);
        }
    }

    enum PhotoMethod {
        CAMERA("camera"),
        FILE("file");

        private final String method;

        PhotoMethod(String method) {
            this.method = method;
        }

        public String getMethod() {
            return method;
        }
    }
}
