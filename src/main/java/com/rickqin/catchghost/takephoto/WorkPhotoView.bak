@Route("")
@JavaScript("./js/camera-util.js")
@JavaScript("./js/image-compress.js")
@PageTitle("Work Photo")
class WorkPhotoView extends VerticalLayout implements BeforeEnterObserver {

    // 长度1-20，只包含字母和数字
    private static final String REGEX_WORKORDER = "^[a-zA-Z0-9]{1,20}$";

    private final TextField txtWorkOrder;
    private final Upload upload;
    private final Button btnUpload;
    private final Button btnShoot;
    private final FlexLayout thumbnailContainer = new FlexLayout();
    private final NotiBox notibox = new NotiBox();

    private final PhotoService photoService;

    public WorkPhotoView(PhotoService photoService) {
        this.photoService = photoService;

        txtWorkOrder = new TextField("Work Order");

        btnUpload = new Button("Upload", VaadinIcon.FILE_ADD.create());
        btnUpload.addThemeVariants(ButtonVariant.LUMO_TERTIARY, ButtonVariant.LUMO_LARGE);
//        btnUpload.addClickListener(e -> {
//            if (validateWorkorderField()) {
//                getElement().executeJs("window.cameraProcessor.startCapture($0, $1)", getElement(), PhotoMethod.FILE.getMethod());
//            }
//        });
        
        InMemoryUploadHandler uploadHandler = new InMemoryUploadHandler((metadata, data) -> {
            String fileName = metadata.fileName();
            String mimeType = metadata.contentType();
            Notification.show(
                    "Uploaded: " + fileName
                    + " (" + data.length / 1024 + " KB)"
            );
            // Example: save to database later
            // photoService.save(fileName, mimeType, data);
        });

        upload = new Upload(uploadHandler);
        upload.setUploadButton(btnUpload);
        upload.setAcceptedFileTypes("image/*");
        upload.setMaxFiles(10);
        upload.setDropAllowed(false);

        

        btnShoot = new Button("Camera", VaadinIcon.CAMERA.create());
        btnShoot.addThemeVariants(ButtonVariant.LUMO_PRIMARY, ButtonVariant.LUMO_LARGE);
        btnShoot.addClickListener(e -> {
            if (validateWorkorderField()) {
                getElement().executeJs("window.cameraProcessor.startCapture($0, $1)", getElement(), PhotoMethod.CAMERA.getMethod());
            }
        });

        thumbnailContainer.setSizeFull();
        thumbnailContainer.setFlexDirection(FlexLayout.FlexDirection.ROW);
        thumbnailContainer.setJustifyContentMode(FlexComponent.JustifyContentMode.CENTER);
        thumbnailContainer.setAlignItems(FlexComponent.Alignment.STRETCH);
        thumbnailContainer.setFlexWrap(FlexLayout.FlexWrap.WRAP);

        setAlignItems(Alignment.CENTER);
        add(new H2("Work Photo"), txtWorkOrder, btnUpload, btnShoot);
        add(thumbnailContainer);
        
        enableClientSideCompression(upload);
    }
    
    private void enableClientSideCompression(Upload upload) {
        upload.getElement().executeJs(REGEX_WORKORDER, parameters)
    }

    @ClientCallable
    public void confirmPhoto(String base64Data) {
        processFinalSave(base64Data, txtWorkOrder.getValue(), null);
    }

    @ClientCallable
    public void retakePhoto(String method) {
        getElement().executeJs("window.cameraProcessor.startCapture($0, $1)", getElement(), PhotoMethod.CAMERA.getMethod());
    }

